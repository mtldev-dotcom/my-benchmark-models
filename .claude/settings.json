{
  "permissions": {
    "allow": [
      "npm run dev",
      "npm run lint",
      "npm run build"
    ],
    "deny": [
      ".env",
      "secrets",
      "database migrations (without approval)",
      "production deploy (without approval)"
    ]
  },
  "workflow": {
    "requireDocsUpdate": true,
    "defaultMode": "plan-then-implement",
    "phase": "phase-1-local-only"
  }
}
